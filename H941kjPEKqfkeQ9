-- Ruby Hub | Grow a Garden 2
-- Fluent rewrite for executor usage

local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local RUBY_DISCORD = "https://discord.gg/nPNvapmuf"
local RUBY_CONFIG_FOLDER = "RubyHub/GrowAGarden2"

local function createRubyHubMacLibCompat()
  local Players = game:GetService("Players")
  local RunService = game:GetService("RunService")
  local Lighting = game:GetService("Lighting")
  local StatsService = game:GetService("Stats")
  local UserInputService = game:GetService("UserInputService")
  local VirtualUser = pcall(function() return game:GetService("VirtualUser") end) and game:GetService("VirtualUser") or nil
  local MarketplaceService = game:GetService("MarketplaceService")
  local LocalPlayer = Players.LocalPlayer
  local startTime = os.time()
  local optionCounter = 0
  local settingsTab
  local settingsBuilt = false
  local unloadCallbacks = {}
  local connections = {}

  local Library = {}
  Library.AutoSave = function() end

  local function notify(title, content, duration)
    pcall(function()
      Fluent:Notify({
        Title = title or "Ruby Hub",
        Content = content or "",
        Duration = duration or 5,
      })
    end)
  end

  function Library:Notify(data)
    data = data or {}
    notify(data.Title or "Ruby Hub", data.Content or data.Description or "", data.Duration or data.Lifetime or 5)
  end

  local function nextId(prefix, customId)
    if customId and tostring(customId) ~= "" then
      return tostring(customId):gsub("%W", "")
    end
    optionCounter = optionCounter + 1
    return (prefix or "Option") .. tostring(optionCounter)
  end

  local function updateParagraph(paragraph, text)
    pcall(function()
      if paragraph.SetDesc then
        paragraph:SetDesc(text)
      elseif paragraph.SetContent then
        paragraph:SetContent(text)
      elseif paragraph.UpdateName then
        paragraph:UpdateName(text)
      end
    end)
  end

  local function getExecutorName()
    local ok, name = pcall(function()
      if identifyexecutor then return identifyexecutor() end
      if getexecutorname then return getexecutorname() end
      return "Unknown"
    end)
    return ok and tostring(name) or "Unknown"
  end

  local function track(connection)
    if connection then table.insert(connections, connection) end
    return connection
  end

  local function iconFor(name)
    name = tostring(name or ""):lower()
    if name:find("farm") then return "sprout" end
    if name:find("boost") then return "flame" end
    if name:find("pet") then return "bone" end
    if name:find("egg") or name:find("crate") then return "package-open" end
    if name:find("shop") then return "shopping-cart" end
    if name:find("steal") then return "hand" end
    if name == "misc" or name:find("misc") then return "sliders-horizontal" end
    if name:find("visual") then return "eye" end
    if name:find("setting") then return "settings" end
    if name:find("information") or name:find("info") then return "info" end
    return "circle"
  end

  local function buildInformation(window)
    local tab = window:AddTab({ Title = "Information", Icon = "info" })
    tab:AddParagraph({
      Title = "Ruby Hub Beta",
      Content = "This Grow a Garden 2 script is still in beta. Some features may be incomplete, unstable, or affected by Roblox and game updates. If you find a bug, need help, or want to report an issue, please join our Discord server and let us know there.",
    })
    tab:AddButton({
      Title = "Copy Discord Link",
      Description = "Copies the Ruby Hub Discord invite to your clipboard.",
      Callback = function()
        if setclipboard then
          setclipboard(RUBY_DISCORD)
          notify("Discord", "Discord invite copied to clipboard.")
        else
          notify("Discord", "Clipboard is not supported by this executor.")
        end
      end,
    })
    tab:AddParagraph({
      Title = "Update Log",
      Content = table.concat({
        "-- Release --    ",
      }, "\n"),
    })
    local infoParagraph = tab:AddParagraph({ Title = "Server Information", Content = "Loading server information..." })
    local frames, fps = 0, 0
    local gameName = "Unknown"
    pcall(function()
      gameName = MarketplaceService:GetProductInfo(game.PlaceId).Name
    end)
    track(RunService.RenderStepped:Connect(function() frames = frames + 1 end))
    task.spawn(function()
      while task.wait(2) do
        fps = frames
        frames = 0
        local ping = "Unknown"
        pcall(function()
          ping = tostring(math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())) .. " ms"
        end)
        local age = os.time() - startTime
        local h = math.floor(age / 3600)
        local m = math.floor((age % 3600) / 60)
        local s = age % 60
        updateParagraph(infoParagraph, table.concat({
          "Game Name: " .. tostring(gameName),
          "Game Id: " .. tostring(game.PlaceId),
          "JobId: " .. tostring(game.JobId),
          string.format("Server Age: %02d:%02d:%02d", h, m, s),
          "Account Name: " .. tostring(LocalPlayer and LocalPlayer.Name or "Unknown"),
          "Player Counter: " .. tostring(#Players:GetPlayers()) .. "/" .. tostring(Players.MaxPlayers),
          "Ping: " .. ping,
          "FPS: " .. tostring(fps),
          "Executor: " .. getExecutorName(),
        }, "\n"))
      end
    end)
  end

  local function applySkybox(name)
    local skyboxes = {
      Default = nil,
      Nebula = {
        Bk = "rbxassetid://159454299", Dn = "rbxassetid://159454296", Ft = "rbxassetid://159454293",
        Lf = "rbxassetid://159454286", Rt = "rbxassetid://159454300", Up = "rbxassetid://159454288",
      },
      Space = {
        Bk = "rbxassetid://166509999", Dn = "rbxassetid://166510057", Ft = "rbxassetid://166510116",
        Lf = "rbxassetid://166510092", Rt = "rbxassetid://166510131", Up = "rbxassetid://166510114",
      },
      Sunset = {
        Bk = "rbxassetid://600830446", Dn = "rbxassetid://600831635", Ft = "rbxassetid://600832720",
        Lf = "rbxassetid://600886090", Rt = "rbxassetid://600833862", Up = "rbxassetid://600835177",
      },
    }
    for _, item in ipairs(Lighting:GetChildren()) do
      if item:IsA("Sky") and item.Name == "RubyHubSkybox" then
        item:Destroy()
      end
    end
    if name == "Default" then
      notify("Skybox", "Default skybox restored.")
      return
    end
    local data = skyboxes[name]
    if not data then return end
    local sky = Instance.new("Sky")
    sky.Name = "RubyHubSkybox"
    sky.SkyboxBk = data.Bk
    sky.SkyboxDn = data.Dn
    sky.SkyboxFt = data.Ft
    sky.SkyboxLf = data.Lf
    sky.SkyboxRt = data.Rt
    sky.SkyboxUp = data.Up
    sky.Parent = Lighting
    notify("Skybox", name .. " skybox applied.")
  end

  local function buildMisc(window)
    local tab = window:AddTab({ Title = "Miscellaneous", Icon = "sliders-horizontal" })
    local movement = {
      walkEnabled = false,
      walkMode = "Humanoid",
      walkSpeed = 32,
      jumpEnabled = false,
      jumpMode = "JumpPower",
      jumpPower = 100,
      flyEnabled = false,
      flyMode = "CFrame",
      flySpeed = 80,
      noclip = false,
      antiAfk = false,
      selectedSkybox = "Nebula",
    }
    local oldLighting = {
      Brightness = Lighting.Brightness,
      ClockTime = Lighting.ClockTime,
      FogEnd = Lighting.FogEnd,
      GlobalShadows = Lighting.GlobalShadows,
      OutdoorAmbient = Lighting.OutdoorAmbient,
    }
    local savedObjects = {}

    tab:AddToggle("RubyWalkspeedToggle", { Title = "Walkspeed Changer", Default = false, Callback = function(v) movement.walkEnabled = v end })
    tab:AddDropdown("RubyWalkspeedMode", { Title = "Walkspeed Changer Mode", Values = { "Humanoid", "Velocity" }, Multi = false, Default = "Humanoid", Callback = function(v) movement.walkMode = tostring(v) end })
    tab:AddSlider("RubyWalkspeedSlider", { Title = "Walkspeed Changer", Default = 32, Min = 16, Max = 300, Rounding = 0, Callback = function(v) movement.walkSpeed = v end })
    tab:AddToggle("RubyJumpToggle", { Title = "Jump Power Changer", Default = false, Callback = function(v) movement.jumpEnabled = v end })
    tab:AddDropdown("RubyJumpMode", { Title = "Jump Power Changer Mode", Values = { "JumpPower", "JumpHeight" }, Multi = false, Default = "JumpPower", Callback = function(v) movement.jumpMode = tostring(v) end })
    tab:AddSlider("RubyJumpSlider", { Title = "Jump Power Changer", Default = 100, Min = 50, Max = 300, Rounding = 0, Callback = function(v) movement.jumpPower = v end })
    tab:AddToggle("RubyFlyToggle", { Title = "Fly", Default = false, Callback = function(v) movement.flyEnabled = v end })
    tab:AddDropdown("RubyFlyMode", { Title = "Fly Mode", Values = { "CFrame", "Velocity" }, Multi = false, Default = "CFrame", Callback = function(v) movement.flyMode = tostring(v) end })
    tab:AddSlider("RubyFlySpeed", { Title = "Fly Speed", Default = 80, Min = 10, Max = 300, Rounding = 0, Callback = function(v) movement.flySpeed = v end })
    tab:AddToggle("RubyNoclipToggle", { Title = "Noclip", Default = false, Callback = function(v) movement.noclip = v end })

    tab:AddDropdown("RubySkyboxDropdown", { Title = "Skybox Changer", Values = { "Default", "Nebula", "Space", "Sunset" }, Multi = false, Default = "Nebula", Callback = function(v) movement.selectedSkybox = tostring(v) end })
    tab:AddButton({ Title = "Apply Skybox", Description = "Applies the selected skybox.", Callback = function() applySkybox(movement.selectedSkybox) end })

    local function setFpsOptimizer(on)
      if on then
        oldLighting.Brightness = Lighting.Brightness
        oldLighting.ClockTime = Lighting.ClockTime
        oldLighting.FogEnd = Lighting.FogEnd
        oldLighting.GlobalShadows = Lighting.GlobalShadows
        oldLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
      else
        Lighting.Brightness = oldLighting.Brightness
        Lighting.ClockTime = oldLighting.ClockTime
        Lighting.FogEnd = oldLighting.FogEnd
        Lighting.GlobalShadows = oldLighting.GlobalShadows
        Lighting.OutdoorAmbient = oldLighting.OutdoorAmbient
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
      end
    end

    local function setAntiLag(on)
      if on then
        table.clear(savedObjects)
        for _, object in ipairs(game:GetDescendants()) do
          pcall(function()
            if object:IsA("ParticleEmitter") or object:IsA("Trail") or object:IsA("Smoke") or object:IsA("Fire") or object:IsA("Sparkles") then
              savedObjects[object] = { Enabled = object.Enabled }
              object.Enabled = false
            elseif object:IsA("Decal") or object:IsA("Texture") then
              savedObjects[object] = { Transparency = object.Transparency }
              object.Transparency = 1
            elseif object:IsA("BasePart") then
              savedObjects[object] = { Material = object.Material, Reflectance = object.Reflectance }
              object.Material = Enum.Material.Plastic
              object.Reflectance = 0
            end
          end)
        end
      else
        for object, props in pairs(savedObjects) do
          pcall(function()
            if object and object.Parent then
              for prop, value in pairs(props) do object[prop] = value end
            end
          end)
        end
        table.clear(savedObjects)
      end
    end

    tab:AddToggle("RubyFPSOptimizer", { Title = "FPS Optimizer", Default = false, Callback = setFpsOptimizer })
    tab:AddToggle("RubyAntiLag", { Title = "Anti Lag", Default = false, Callback = setAntiLag })
    tab:AddToggle("RubyAntiAFK", { Title = "Anti AFK", Default = false, Callback = function(v) movement.antiAfk = v end })
    tab:AddSlider("RubyFOVChanger", { Title = "FOV Changer", Default = 70, Min = 40, Max = 120, Rounding = 0, Callback = function(v) pcall(function() workspace.CurrentCamera.FieldOfView = v end) end })

    pcall(function()
      LocalPlayer.Idled:Connect(function()
        if movement.antiAfk and VirtualUser then
          VirtualUser:CaptureController()
          VirtualUser:ClickButton2(Vector2.new(0, 0))
        end
      end)
    end)

    track(RunService.Heartbeat:Connect(function(dt)
      if not (movement.walkEnabled or movement.jumpEnabled or movement.flyEnabled) then return end
      local char = LocalPlayer.Character
      local hum = char and char:FindFirstChildOfClass("Humanoid")
      local root = char and char:FindFirstChild("HumanoidRootPart")
      if hum and movement.walkEnabled then
        if movement.walkMode == "Humanoid" then
          hum.WalkSpeed = movement.walkSpeed
        elseif root and hum.MoveDirection.Magnitude > 0 then
          root.CFrame = root.CFrame + hum.MoveDirection * movement.walkSpeed * dt
        end
      end
      if hum and movement.jumpEnabled then
        if movement.jumpMode == "JumpHeight" then
          hum.UseJumpPower = false
          hum.JumpHeight = movement.jumpPower / 7
        else
          hum.UseJumpPower = true
          hum.JumpPower = movement.jumpPower
        end
      end
      if root and movement.flyEnabled then
        local camera = workspace.CurrentCamera
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
        if dir.Magnitude > 0 then dir = dir.Unit end
        if movement.flyMode == "Velocity" then
          root.AssemblyLinearVelocity = dir * movement.flySpeed
        else
          root.CFrame = root.CFrame + dir * movement.flySpeed * dt
          root.AssemblyLinearVelocity = Vector3.zero
        end
      end
    end))

    track(RunService.Stepped:Connect(function()
      if movement.noclip and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
          if part:IsA("BasePart") then part.CanCollide = false end
        end
      end
    end))
  end

  local function buildVisuals(window)
    local tab = window:AddTab({ Title = "Visuals", Icon = "eye" })
    local visuals = {
      highlight = false,
      highlightTransparency = 0.45,
      highlightColor = Color3.fromRGB(255, 80, 120),
      names = false,
      nameColor = Color3.new(1, 1, 1),
      distance = true,
    }
    local cache = {}

    local function clearPlayer(player)
      local entry = cache[player]
      if entry then
        for _, obj in pairs(entry) do pcall(function() obj:Destroy() end) end
        cache[player] = nil
      end
    end

    local function ensurePlayer(player)
      if player == LocalPlayer then return end
      local char = player.Character
      local root = char and char:FindFirstChild("HumanoidRootPart")
      if not char or not root then clearPlayer(player); return end
      cache[player] = cache[player] or {}
      if visuals.highlight and not cache[player].Highlight then
        local hl = Instance.new("Highlight")
        hl.Name = "RubyHubPlayerHighlight"
        hl.Parent = char
        cache[player].Highlight = hl
      end
      if cache[player].Highlight then
        cache[player].Highlight.Enabled = visuals.highlight
        cache[player].Highlight.FillColor = visuals.highlightColor
        cache[player].Highlight.OutlineColor = Color3.new(1, 1, 1)
        cache[player].Highlight.FillTransparency = visuals.highlightTransparency
        cache[player].Highlight.OutlineTransparency = 0
      end
      if visuals.names and not cache[player].Billboard then
        local bill = Instance.new("BillboardGui")
        bill.Name = "RubyHubPlayerName"
        bill.Size = UDim2.new(0, 220, 0, 42)
        bill.StudsOffset = Vector3.new(0, 3, 0)
        bill.AlwaysOnTop = true
        bill.Parent = root
        local text = Instance.new("TextLabel")
        text.Name = "Text"
        text.BackgroundTransparency = 1
        text.Size = UDim2.fromScale(1, 1)
        text.Font = Enum.Font.GothamBold
        text.TextSize = 14
        text.TextStrokeTransparency = 0
        text.Parent = bill
        cache[player].Billboard = bill
        cache[player].Text = text
      end
      if cache[player].Billboard then
        cache[player].Billboard.Enabled = visuals.names
        if cache[player].Text then
          local dist = ""
          pcall(function()
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if visuals.distance and myRoot then
              dist = " [" .. tostring(math.floor((myRoot.Position - root.Position).Magnitude)) .. "m]"
            end
          end)
          cache[player].Text.Text = player.Name .. dist
          cache[player].Text.TextColor3 = visuals.nameColor
        end
      end
    end

    tab:AddToggle("RubyPlayerHighlight", { Title = "Player Highlight", Default = false, Callback = function(v) visuals.highlight = v if not v then for p in pairs(cache) do if cache[p].Highlight then cache[p].Highlight.Enabled = false end end end end })
    tab:AddSlider("RubyPlayerHighlightTransparency", { Title = "Player Highlight Transparency", Default = 0.45, Min = 0, Max = 1, Rounding = 2, Callback = function(v) visuals.highlightTransparency = v end })
    tab:AddColorpicker("RubyPlayerHighlightColor", { Title = "Player Highlight Color", Default = visuals.highlightColor, Callback = function(v) visuals.highlightColor = v end })
    tab:AddToggle("RubyPlayerName", { Title = "Player Name", Default = false, Callback = function(v) visuals.names = v if not v then for p in pairs(cache) do if cache[p].Billboard then cache[p].Billboard.Enabled = false end end end end })
    tab:AddColorpicker("RubyPlayerNameColor", { Title = "Player Name Color", Default = visuals.nameColor, Callback = function(v) visuals.nameColor = v end })
    tab:AddToggle("RubyPlayerDistance", { Title = "Player Distance", Default = true, Callback = function(v) visuals.distance = v end })

    track(Players.PlayerRemoving:Connect(clearPlayer))
    task.spawn(function()
      while task.wait(0.25) do
        if visuals.highlight or visuals.names then
          for _, player in ipairs(Players:GetPlayers()) do ensurePlayer(player) end
        end
      end
    end)
  end

  local function makeSection(tab)
    local section = {}
    function section:Header(opts)
      tab:AddParagraph({ Title = tostring((opts and opts.Text) or "Section"), Content = "" })
    end
    function section:Label(opts)
      local text = type(opts) == "table" and opts.Text or tostring(opts or "")
      local paragraph = tab:AddParagraph({ Title = "", Content = text })
      return {
        UpdateName = function(_, newText) updateParagraph(paragraph, tostring(newText or "")) end,
        Set = function(_, newText) updateParagraph(paragraph, tostring(newText or "")) end,
      }
    end
    function section:Button(opts)
      opts = opts or {}
      return tab:AddButton({ Title = opts.Name or opts.Title or "Button", Description = opts.Description or "", Callback = opts.Callback or function() end })
    end
    function section:Toggle(opts, id)
      opts = opts or {}
      return tab:AddToggle(nextId("Toggle", id), { Title = opts.Name or opts.Title or "Toggle", Default = opts.Default or false, Callback = opts.Callback or function() end })
    end
    function section:Dropdown(opts, id)
      opts = opts or {}
      return tab:AddDropdown(nextId("Dropdown", id), { Title = opts.Name or opts.Title or "Dropdown", Values = opts.Options or opts.Values or {}, Multi = opts.Multi or false, Default = opts.Default, Callback = opts.Callback or function() end })
    end
    function section:Slider(opts, id)
      opts = opts or {}
      return tab:AddSlider(nextId("Slider", id), { Title = opts.Name or opts.Title or "Slider", Default = opts.Default or opts.Minimum or 0, Min = opts.Minimum or opts.Min or 0, Max = opts.Maximum or opts.Max or 100, Rounding = opts.Precision or 0, Callback = opts.Callback or function() end })
    end
    function section:Input(opts, id)
      opts = opts or {}
      if tab.AddInput then
        return tab:AddInput(nextId("Input", id), { Title = opts.Name or opts.Title or "Input", Default = opts.Default or "", Placeholder = opts.Placeholder or "", Numeric = false, Finished = false, Callback = opts.Callback or function() end })
      end
      return section:Button({ Name = opts.Name or "Input unavailable", Callback = function() notify("Input", "Input is not supported by this Fluent build.") end })
    end
    return section
  end

  local function makeTab(tab)
    return {
      Section = function(_, opts)
        return makeSection(tab)
      end,
    }
  end

  function Library:Window(opts)
    opts = opts or {}
    local window = Fluent:CreateWindow({
      Title = "Ruby Hub | Grow a Garden 2",
      SubTitle = "made by Ruby Hub Team",
      TabWidth = 160,
      Size = opts.Size or UDim2.fromOffset(860, 620),
      Acrylic = false,
      Theme = "Rose",
      MinimizeKey = opts.Keybind or Enum.KeyCode.RightShift,
    })

    buildInformation(window)

    local compatWindow = {}
    function compatWindow:TabGroup()
      return {
        Tab = function(_, tabOpts)
          tabOpts = tabOpts or {}
          local title = tabOpts.Name or tabOpts.Title or "Tab"
          local tab = window:AddTab({ Title = title, Icon = iconFor(title) })
          if tostring(title):lower():find("setting") then settingsTab = tab end
          return makeTab(tab)
        end,
      }
    end
    function compatWindow:SetScale() end
    function compatWindow:GetAcrylicBlurState() return true end
    function compatWindow:SetAcrylicBlurState() end
    function compatWindow:GetNotificationsState() return true end
    function compatWindow:SetNotificationsState() end
    function compatWindow:GlobalSetting(opts, id)
      opts = opts or {}
      local tab = settingsTab or window:AddTab({ Title = "UI Settings", Icon = "settings" })
      return tab:AddToggle(nextId("Global", id), { Title = opts.Name or opts.Title or "Setting", Default = opts.Default or false, Callback = opts.Callback or function() end })
    end
    function compatWindow:CreateMinimizer() end
    function compatWindow:Unload()
      for _, cb in ipairs(unloadCallbacks) do pcall(cb) end
      for _, connection in ipairs(connections) do pcall(function() connection:Disconnect() end) end
      pcall(function()
        if window.Destroy then window:Destroy() elseif window.Unload then window:Unload() end
      end)
    end
    compatWindow.onUnloaded = function(callback)
      if type(callback) == "function" then table.insert(unloadCallbacks, callback) end
    end
    return compatWindow
  end

  local function buildSettingsIfNeeded()
    if settingsBuilt or not settingsTab then return end
    settingsBuilt = true
    pcall(function()
      SaveManager:SetLibrary(Fluent)
      InterfaceManager:SetLibrary(Fluent)
      SaveManager:IgnoreThemeSettings()
      SaveManager:SetIgnoreIndexes({})
      InterfaceManager:SetFolder("RubyHub")
      SaveManager:SetFolder(RUBY_CONFIG_FOLDER)
      InterfaceManager:BuildInterfaceSection(settingsTab)
      SaveManager:BuildConfigSection(settingsTab)
    end)
  end

  function Library:SetFolder() end
  function Library:RefreshConfigList() return { "default" } end
  function Library:SaveConfig() buildSettingsIfNeeded() end
  function Library:LoadAutoLoadConfig()
    buildSettingsIfNeeded()
    pcall(function() SaveManager:LoadAutoloadConfig() end)
  end

  return Library
end
