local _fpsApplied = false
local _fpsSaved = { lighting = nil, objects = {}, connection = nil }
local function tuneVisualObject(object, save)
  if object:IsA("ParticleEmitter") or object:IsA("Trail") or object:IsA("Smoke") or object:IsA("Fire") or object:IsA("Sparkles") then
    if save and _fpsSaved.objects[object] == nil then _fpsSaved.objects[object] = { Enabled = object.Enabled } end
    object.Enabled = false
  elseif object:IsA("Texture") or object:IsA("Decal") then
    if save and _fpsSaved.objects[object] == nil then _fpsSaved.objects[object] = { Transparency = object.Transparency } end
    pcall(function() object.Transparency = 1 end)
  elseif object:IsA("BasePart") then
    if save and _fpsSaved.objects[object] == nil then
      _fpsSaved.objects[object] = { Material = object.Material, Reflectance = object.Reflectance, CastShadow = object.CastShadow }
    end
    pcall(function()
      object.Material = Enum.Material.Plastic
      object.Reflectance = 0
      object.CastShadow = false
    end)
  end
end
local function applyFpsBoost(on)
  if on and not _fpsApplied then
    _fpsApplied = true
    _fpsSaved.lighting = {
      GlobalShadows = Lighting.GlobalShadows,
      FogEnd = Lighting.FogEnd,
      Brightness = Lighting.Brightness,
      ClockTime = Lighting.ClockTime,
    }
    pcall(function()
      Lighting.GlobalShadows = false; Lighting.FogEnd = 1e6; Lighting.Brightness = 2; Lighting.ClockTime = 14
      for _, e in ipairs(Lighting:GetChildren()) do
        if e:IsA("BloomEffect") or e:IsA("SunRaysEffect") or e:IsA("DepthOfFieldEffect") or e:IsA("BlurEffect") then e.Enabled = false end
      end
      if sethiddenproperty then pcall(sethiddenproperty, Lighting, "Technology", 1) end
      settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    task.spawn(function()
      for _, d in ipairs(Workspace:GetDescendants()) do
        if not S.fpsBoost then break end
        tuneVisualObject(d, true)
      end
    end)
    _fpsSaved.connection = Workspace.DescendantAdded:Connect(function(d)
      if S.fpsBoost then pcall(function() tuneVisualObject(d, true) end) end
    end)
  elseif not on and _fpsApplied then
    _fpsApplied = false
    if _fpsSaved.connection then pcall(function() _fpsSaved.connection:Disconnect() end); _fpsSaved.connection = nil end
    if _fpsSaved.lighting then
      pcall(function()
        Lighting.GlobalShadows = _fpsSaved.lighting.GlobalShadows
        Lighting.FogEnd = _fpsSaved.lighting.FogEnd
        Lighting.Brightness = _fpsSaved.lighting.Brightness
        Lighting.ClockTime = _fpsSaved.lighting.ClockTime
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
      end)
    end
    for object, props in pairs(_fpsSaved.objects) do
      if object and object.Parent then
        pcall(function()
          for prop, value in pairs(props) do object[prop] = value end
        end)
      end
    end
    table.clear(_fpsSaved.objects)
    _fpsSaved.lighting = nil
  end
end

